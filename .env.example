# Supabase
# Get these values from your Supabase project dashboard at https://supabase.com
# Project URL format: https://abcdefghijklmnop.supabase.co
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Anonymous key starts with 'eyJ' and is very long (200+ characters)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImpkY3NvZ3d3cmJ6a3FoaGFkamx2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTk5MDIxNzcsImV4cCI6MjA3NTQ3ODE3N30.1sEQpAqeBzXm6GqYlOYPFCzTjpcBxj7qbOFLD1tX0cM
# CRITICAL: Functions URL format: https://abcdefghijklmnop.functions.supabase.co
# This MUST be set for chat and AI features to work properly
VITE_SUPABASE_FUNCTIONS_URL=https://your-project-ref.functions.supabase.co
# Project ID (used in supabase/config.toml)
SUPABASE_PROJECT_ID=your-project-id-here

# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Netlify
NETLIFY_AUTH_TOKEN=your_netlify_personal_access_token

# Edge Function Secrets (Configure in Supabase Dashboard → Edge Functions → Secrets)
# These are NOT frontend variables - they are only available in Supabase Edge Functions

# Uhuru LLM Configuration (for uhuru-llm-api and uhuru-whatsapp-api)
# CRITICAL: Use OrionX API endpoint for chat responses
UHURU_API_URL=https://api.orionx.ai/v1/chat/response
# CRITICAL: Image generation endpoint
UHURU_IMAGES_URL=https://api.orionx.ai/v1/images/generations
# API key for authentication
UHURU_API_KEY=your-api-key-here
# Text model identifier for Uhuru 2.0 (used for chat conversations)
UHURU_MODEL_20=uhuru-2.0-base
# Image model identifiers (used for image generation)
# UHURU_IMAGE_MODEL_20: Craft-1 image model (fast generation)
# UHURU_IMAGE_MODEL_21: Craft-2 image model (advanced with background transparency)
UHURU_IMAGE_MODEL_20=uhuru-craft-1
UHURU_IMAGE_MODEL_21=uhuru-craft-2

# Internal API Key (for secure Supabase edge function communication)
UHURU_INTERNAL_API_KEY=your-secure-random-uuid

# Twilio Configuration (for WhatsApp functionality)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=+1234567890
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WhatsApp API URL (points to uhuru-whatsapp-api edge function)
UHURU_WHATSAPP_API_URL=https://wsanzctysxvclrqhfxqa.supabase.co/functions/v1/uhuru-whatsapp-api
# Sentry (Error Tracking - Optional but highly recommended for production)
# Get your DSN from https://sentry.io/
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
VITE_APP_VERSION=0.1.0
